{
  "private": true,
  "name": "synlinea-theia",
  "version": "0.0.0",
  "workspaces": [
    "applications/*",
    "packages/*"
  ],
  "scripts": {
    "build:packages": "npm run build --workspaces --if-present",
    "build": "npm run build:packages && npm run build:browser --workspace=applications/browser",
    "build:browser": "npm run build:packages && npm run build:browser --workspace=applications/browser",
    "start": "npm run start:browser --workspace=applications/browser",
    "start:browser": "npm run start:browser --workspace=applications/browser",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check \"applications/**/*.ts\" \"packages/**/*.ts\"",
    "format:fix": "prettier --write \"applications/**/*.ts\" \"packages/**/*.ts\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.5.0",
    "lerna": "^8.2.4"
  },
  "engines": {
    "node": ">=22 <=24"
  }
}
