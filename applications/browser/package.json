{
  "private": true,
  "name": "@synlinea/browser-app",
  "version": "0.0.0",
  "dependencies": {
    "@theia/core": "1.72.3",
    "@theia/editor": "1.72.3",
    "@theia/monaco": "1.72.3",
    "@theia/preview": "1.72.3",
    "@theia/terminal": "1.72.3",
    "@theia/filesystem": "1.72.3",
    "@theia/workspace": "1.72.3",
    "@theia/navigator": "1.72.3",
    "@theia/messages": "1.72.3",
    "@theia/preferences": "1.72.3",
    "@theia/scm": "1.72.3",
    "@theia/scm-extra": "1.72.3",
    "@theia/plugin-ext": "1.72.3",
    "@theia/plugin-ext-vscode": "1.72.3",
    "@synlinea/skill-manager": "*",
    "@synlinea/usage-monitor": "*"
  },
  "devDependencies": {
    "@theia/cli": "1.72.3"
  },
  "scripts": {
    "build:browser": "theia download:plugins && theia build --mode development",
    "download:plugins": "theia download:plugins",
    "start:browser": "theia start --plugins=local-dir:plugins",
    "clean": "theia clean"
  },
  "theiaPluginsDir": "plugins",
  "theiaPlugins": {
    "vscode.git": "https://open-vsx.org/api/vscode/git/1.95.3/file/vscode.git-1.95.3.vsix",
    "vscode.git-base": "https://open-vsx.org/api/vscode/git-base/1.95.3/file/vscode.git-base-1.95.3.vsix",
    "mhutchie.git-graph": "https://open-vsx.org/api/mhutchie/git-graph/1.30.0/file/mhutchie.git-graph-1.30.0.vsix"
  },
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "Synlinea"
      }
    }
  }
}
