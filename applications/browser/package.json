{
  "private": true,
  "name": "@synlinea/browser-app",
  "version": "0.0.0",
  "dependencies": {
    "@theia/core": "1.72.3",
    "@theia/editor": "1.72.3",
    "@theia/monaco": "1.72.3",
    "@theia/preview": "1.72.3",
    "@theia/terminal": "1.72.3",
    "@theia/filesystem": "1.72.3",
    "@theia/workspace": "1.72.3",
    "@theia/navigator": "1.72.3",
    "@theia/messages": "1.72.3",
    "@theia/preferences": "1.72.3",
    "@synlinea/skill-manager": "*"
  },
  "devDependencies": {
    "@theia/cli": "1.72.3"
  },
  "scripts": {
    "build:browser": "theia build --mode development",
